# Galatasaray Football Management System - Environment Variables
# Copy this file to .env and update the values for your environment

# Database Configuration (Supabase PostgreSQL)
SUPABASE_CONNECTION_STRING=Server=your-supabase-host;Port=5432;Database=your-database;User Id=your-username;Password=your-password;

# ASP.NET Core Environment
ASPNETCORE_ENVIRONMENT=Production

# Logging Configuration
LOG_LEVEL=Information
ASPNET_LOG_LEVEL=Warning

# Security Configuration
ALLOWED_HOSTS=localhost,yourdomain.com

# Optional: If using local PostgreSQL instead of Supabase
# POSTGRES_DB=galatasaray_db
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your-secure-password

# Docker Configuration
COMPOSE_PROJECT_NAME=galatasaray-management

# Application Settings
APP_NAME=Galatasaray Football Management System
APP_VERSION=1.0.0